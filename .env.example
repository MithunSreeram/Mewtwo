# Anthropic API key — required for AI features
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use (defaults to claude-opus-4-5)
MEWTWO_MODEL=claude-opus-4-5

# HTTP proxy for all outbound requests (optional)
# MEWTWO_PROXY=http://127.0.0.1:8080

# Root directory for workspaces (defaults to ~/.mewtwo/workspaces)
# MEWTWO_WORKSPACES_DIR=/path/to/workspaces

# Request timeout in seconds (default: 30)
# MEWTWO_TIMEOUT=30

# Max concurrent HTTP requests (default: 20)
# MEWTWO_CONCURRENCY=20
